    <!-- =====================================================
         API TESTS — no browser needed, very lightweight
    ===================================================== -->

    <test name="API – Positive"
          parallel="classes"
          thread-count="2">
        <classes>
            <class name="com.notes.tests.api.NotesApiTests"/>
            <class name="com.notes.tests.api.DeleteNoteApi"/>
        </classes>
    </test>

    <test name="API – Negative"
          parallel="classes"
          thread-count="2">
        <classes>
            <class name="com.notes.tests.api.negative.CreateNoteNegativeTests"/>
            <class name="com.notes.tests.api.negative.DeleteNegativeTests"/>
            <class name="com.notes.tests.api.negative.LoginNegativeTests"/>
        </classes>
    </test>

    <!-- =====================================================
         E2E — sequential, one browser at a time
    ===================================================== -->

    <test name="E2E – UI to API Validation"
          parallel="false"
          preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.notes.tests.e2e.UiToApiValidationTests"/>
        </classes>
    </test>

    <test name="E2E – API to UI Delete Validation"
          parallel="false"
          preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.notes.tests.e2e.ApiToUiDeleteValidationTests"/>
        </classes>
    </test>
    <test name="E2E – API to UI Defect validation"
          parallel="false"
          preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.notes.tests.e2e.ApiToUiValidationTest"/>
        </classes>
    </test>

</suite>