<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Full Automation Suite"
       parallel="tests"
       thread-count="2"
       verbose="1">

    <listeners>
        <listener class-name="com.notes.utils.McpTestListener"/>
    </listeners>

    <!-- =====================================================
         UI TESTS — Chrome
    ===================================================== -->

    <test name="UI – Registration (Chrome)"
          parallel="false"
          thread-count="1"
          preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <groups><run><include name="registration"/></run></groups>
        <classes>
            <class name="com.notes.tests.ui.RegistrationTests"/>
        </classes>
    </test>

    <test name="UI – Login (Chrome)"
          parallel="false"
          thread-count="1"
          preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <groups><run><include name="login"/></run></groups>
        <classes>
            <class name="com.notes.tests.ui.LoginTests"/>
        </classes>
    </test>

    <test name="UI – Note Creation (Chrome)"
          parallel="false"
          thread-count="1"
          preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <groups><run><include name="notes"/></run></groups>
        <classes>
            <class name="com.notes.tests.ui.NoteCreationTests"/>
        </classes>
    </test>

